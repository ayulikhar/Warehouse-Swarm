          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/White</name></script></material>
        </visual>
      </link>
    </model>

    <!-- Shelf Row 1 (left side) -->
    <model name="shelf_1_1">
      <static>true</static>
      <pose>-6 6 0.75 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.4 3.0 1.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.4 3.0 1.5</size></box></geometry>
