    <!-- Zone A: Green, Position (0, 0) -->
    <model name="zone_A">
      <static>true</static>
      <pose>0 0 0.015 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.4</radius>
              <length>0.01</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.4</radius>
              <length>0.01</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0 1 0 1</ambient>
            <diffuse>0 1 0 1</diffuse>
            <specular>0 0.1 0 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Zone B: Blue, Position (-4, 5) -->
    <model name="zone_B">
      <static>true</static>
